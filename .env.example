# Azure Blob Storage
BLOB_STORAGE_TYPE=azure
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=

# Email Auth
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_FROM=
SMTP_PASS=

# OpenAI API (Azure AI Foundry)
AZURE_OPENAI_ENDPOINT=https://{resource}.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview
AZURE_OPENAI_API_KEY=

# PostgreSQL (production) — least-privilege morning_briefings_app role
# Use port 6432 for PgBouncer, 5432 for direct Postgres
DATABASE_URL=postgresql://morning_briefings_app:<password>@un80-dev-pg.postgres.database.azure.com:6432/morning_meetings?sslmode=require

# PostgreSQL (development) — used automatically when NODE_ENV=development
# skipped if commented out
# DATABASE_URL_DEV=postgresql://morning_briefings_dev:<password>@un80-dev-pg.postgres.database.azure.com:6432/morning_meetings_dev?sslmode=require

# Cron job (Vercel)
CRON_SECRET=
# Set to an email address to send cron briefings only to that address (for testing)
# CRON_TEST_EMAIL=

# Next.js
NEXTAUTH_URL=http://localhost:3000

# openssl rand -base64 32
NEXTAUTH_SECRET=

