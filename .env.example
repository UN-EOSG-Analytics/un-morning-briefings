## Synonymous:
DATABASE_URL=

# Next.js
# NEXTAUTH_URL — only set this for non-Vercel deployments (e.g. custom server)
# On Vercel, this is auto-detected. Do not set it locally.

# openssl rand -base64 32
NEXTAUTH_SECRET=

